    -- [ ПИКСЕЛЬНАЯ ПОЛОСА ]
    local sliderBack = Instance.new("Frame", frame)
    sliderBack.Name = "SliderBack"
    sliderBack.Size = UDim2.new(1, -50, 0, 4)
    sliderBack.Position = UDim2.new(0, 25, 0, 45)
    sliderBack.BackgroundColor3 = CURRENT_THEME.Accent
    sliderBack.BackgroundTransparency = 0.6
    sliderBack.BorderSizePixel = 0

    -- Делаем эффект "пунктира" через текстуру или UIListLayout с квадратами
    local dotContainer = Instance.new("Frame", sliderBack)
    dotContainer.Size = UDim2.new(1, 0, 1, 0); dotContainer.BackgroundTransparency = 1
    local layout = Instance.new("UIListLayout", dotContainer)
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Padding = UDim.new(0, 8)

    for i = 1, 15 do -- Создаем визуальные "точки" для пиксельности
        local d = Instance.new("Frame", dotContainer)
        d.Size = UDim2.new(0, 4, 0, 4); d.BackgroundColor3 = CURRENT_THEME.Accent; d.BorderSizePixel = 0
    end

    local sliderFill = Instance.new("Frame", sliderBack)
    sliderFill.Name = "AccentPart"
    sliderFill.Size = UDim2.new((sliderData.Value - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = CURRENT_THEME.Accent
    sliderFill.BorderSizePixel = 0

    local mainBtn = Instance.new("TextButton", sliderBack)
    mainBtn.Size = UDim2.new(1, 20, 1, 20); mainBtn.Position = UDim2.new(0, -10, 0, -10)
    mainBtn.BackgroundTransparency = 1; mainBtn.Text = ""

    local sliderDot = Instance.new("Frame", sliderFill)
    sliderDot.Name = "SliderDot"
    sliderDot.Size = UDim2.new(0, 10, 0, 10)
    sliderDot.AnchorPoint = Vector2.new(0.5, 0.5)
    sliderDot.Position = UDim2.new(1, 0, 0.5, 0)
    sliderDot.BackgroundColor3 = CURRENT_THEME.Background
    sliderDot.BorderSizePixel = 2
    sliderDot.BorderColor3 = CURRENT_THEME.Accent
    sliderDot.Rotation = 45 -- Повернутый квадрат

    -- [ ЛОГИКА ]
    local function update(input)
        local pos = math.clamp((input.Position.X - sliderBack.AbsolutePosition.X) / sliderBack.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pos)
        
        sliderData.Value = val
        inputField.Text = tostring(val)
        sliderFill.Size = UDim2.new(pos, 0, 1, 0)
        callback(val)
    end

    local dragging = false
    mainBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            dragging = true 
            update(input)
            if PlayClickSound then PlayClickSound() end
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    -- Логика ручного ввода в бокс
    inputField.FocusLost:Connect(function()
        local val = tonumber(inputField.Text)
        if not val then 
            inputField.Text = tostring(sliderData.Value)
            return 
        end
        
        val = math.clamp(val, min, max)
        sliderData.Value = val
        inputField.Text = tostring(val)
        
        local pos = (val - min) / (max - min)
        TweenService:Create(sliderFill, TweenInfo.new(0.3), {Size = UDim2.new(pos, 0, 1, 0)}):Play()
        callback(val)
    end)

    -- Анимация наведения на весь фрейм (как у кнопок)
    applyInteraction(mainBtn, sliderDot) 
end
            

