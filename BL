local function PrepareTeleport()
    local qot = queue_on_teleport or (syn and syn.queue_on_teleport)
    if qot then
        -- Формируем скрипт для выполнения на новом сервере
        qot([[
            -- Передаем все настройки в глобальные переменные нового сервера
            _G.AutoRunRaid = "]] .. tostring(_G.AutoRunRaid or "None") .. [["
            _G.AutoRetryEnabled = ]] .. tostring(_G.AutoRetryEnabled or false) .. [[
            _G.AutoSummonEnabled = ]] .. tostring(_G.AutoSummonEnabled or false) .. [[
            
            task.wait(5)
            
            -- Загружаем основной скрипт
            loadstring(game:HttpGet("https://raw.githubusercontent.com/metegh/BizzareLineage/refs/heads/main/BL", true))()
            
            -- Закрытие меню и спавн (дублируем для надежности)
            pcall(function()
                local player = game:GetService("Players").LocalPlayer
                if player.PlayerGui:FindFirstChild("Main Menu") then
                    player.PlayerGui["Main Menu"].Enabled = false
                end
                game:GetService("ReplicatedStorage"):WaitForChild("requests"):WaitForChild("character"):WaitForChild("spawn"):FireServer()
            end)
        ]])
    end
end

