    local function AnimateTextReveal(textLabel, targetText, duration)
    local startTime = tick()
    local targetLength = #targetText
    
    local connection
    connection = game:GetService("RunService").RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        local progress = math.min(elapsed / duration, 1)
        
        local revealedCount = math.floor(targetLength * progress)
        
        local displayText = ""
        
        for i = 1, revealedCount do
            displayText = displayText .. targetText:sub(i, i)
        end
        
        for i = revealedCount + 1, targetLength do
            displayText = displayText .. string.char(math.random(65, 122))
        end
        
        textLabel.Text = displayText
        
        if progress >= 1 then
            textLabel.Text = targetText
            connection:Disconnect()
        end
    end)
