    local state = default
    
    -- Функция переключения (вынесена отдельно)
    local function toggle(newState)
        if newState == nil then state = not state else state = newState end
        game:GetService("TweenService"):Create(tTxt, TweenInfo.new(0.2), {Position = state and UDim2.new(0,0,0,0) or UDim2.new(-1,0,0,0)}):Play()
        callback(state)
    end

    applyInteraction(frame, box, function()
        toggle()
    end)

    -- Возвращаем объект, чтобы управлять им программно
