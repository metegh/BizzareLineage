function Library:Notify(titleText, descText, duration)
    if not Library.NotificationsEnabled or not Library.NotifyContainer then return end
    
    local waitTime = duration or 3
    
    local nFrame = Instance.new("Frame", Library.NotifyContainer)
    nFrame.Name = "ParagraphFrame"
    nFrame.Size = UDim2.new(0, 280, 0, 70)
    nFrame.BackgroundColor3 = CURRENT_THEME.Row
    nFrame.BorderSizePixel = 0
    nFrame.ClipsDescendants = true -- Чтобы полоска не вылезала при анимации

    -- Полоска-таймер (AccentPart)
    local acc = Instance.new("Frame", nFrame)
    acc.Name = "AccentPart"
    acc.Size = UDim2.new(1, 0, 0, 4) -- Начинаем с полной ширины (1)
    acc.Position = UDim2.new(0, 0, 1, -4)
    acc.BackgroundColor3 = CURRENT_THEME.Accent
    acc.BorderSizePixel = 0
    acc.ZIndex = 5

    local tL = Instance.new("TextLabel", nFrame)
    tL.Text = "  "..titleText:upper()
    tL.Size = UDim2.new(1, 0, 0, 25)
    tL.TextColor3 = CURRENT_THEME.Accent
    tL.Font = Enum.Font.GothamBold
    tL.TextSize = 14
    tL.TextXAlignment = Enum.TextXAlignment.Left
    tL.BackgroundTransparency = 1

    local dL = Instance.new("TextLabel", nFrame)
    dL.Text = "  "..descText
    dL.Size = UDim2.new(1, 0, 1, -25)
    dL.Position = UDim2.new(0, 0, 0, 25)
    dL.TextColor3 = CURRENT_THEME.Text
    dL.Font = Enum.Font.Gotham
    dL.TextSize = 13
    dL.TextXAlignment = Enum.TextXAlignment.Left
    dL.TextYAlignment = Enum.TextYAlignment.Top
    dL.BackgroundTransparency = 1

    -- === АНИМАЦИЯ ПОЛОСКИ (ТАЙМЕР) ===
    -- Мы уменьшаем Scale по X до 0 за время waitTime
    local timerTween = TweenService:Create(acc, TweenInfo.new(waitTime, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 0, 4)
    })
    
    timerTween:Play()

    -- Удаление уведомления после завершения
    task.delay(waitTime, function()
        -- Можно добавить плавное исчезновение самого фрейма перед удалением
        local fadeOut = TweenService:Create(nFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1})
        fadeOut:Play()
        fadeOut.Completed:Connect(function()
            nFrame:Destroy()
        end)
    end)
end

